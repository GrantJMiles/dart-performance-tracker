@page "/matchday"
@using DartPerformanceTracker.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Match Night Entry</PageTitle>

<div style="max-width: 640px; margin: 0 auto;">

@if (step == Step.Setup)
{
    <h3>New Match Night</h3>

    <FluentCard Style="margin-bottom: 1rem; padding: 1rem;">
        <div style="margin-bottom: 1rem;">
            <label class="form-label">Season</label>
            <FluentSelect TOption="string" Value="@(selectedSeason?.Id.ToString() ?? "0")"
                          ValueChanged="@OnSeasonChanged"
                          style="width: 100%;">
                <FluentOption Value="@("0")">-- Select Season --</FluentOption>
                @foreach (var season in seasons)
                {
                    <FluentOption Value="@season.Id.ToString()">@season.Name</FluentOption>
                }
            </FluentSelect>
        </div>
        @if (selectedSeason != null)
        {
            <div style="margin-bottom: 1rem;">
                <label class="form-label">Date</label>
                <FluentDatePicker Value="@((DateTime?)setupDate)"
                                  ValueChanged="@(v => setupDate = v ?? DateTime.Today)"
                                  style="width: 100%;" />
            </div>
            <div style="margin-bottom: 1rem;">
                <FluentTextField @bind-Value="setupOpponent" Label="Opponent" Placeholder="Opponent team name" style="width: 100%;" />
            </div>
            <div style="margin-bottom: 1rem;">
                <FluentCheckbox @bind-Value="setupIsHome" Label="Home Game" />
            </div>
            <div style="margin-bottom: 1rem;">
                <p style="color: var(--neutral-foreground-hint); font-size: 0.875rem; margin-bottom: 0.25rem;">
                    <strong>@orderedConfigs.Count matches</strong> in this season's format:
                    @string.Join(", ", orderedConfigs.Select(c => c.MatchTypeName))
                </p>
            </div>
            <FluentButton Appearance="Appearance.Accent" @onclick="BeginMatchNight"
                          Disabled="@(saving || string.IsNullOrWhiteSpace(setupOpponent))">
                @if (saving) { <FluentProgressRing Style="width: 16px; height: 16px; margin-right: 4px;" /> }
                Begin Match Night
            </FluentButton>
        }
    </FluentCard>
}
else if (step == Step.Matches && createdGameNight != null)
{
    var config = orderedConfigs[currentMatchIndex];

    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
        <h3 style="margin: 0;">Match @(currentMatchIndex + 1) of @totalMatches</h3>
        <FluentBadge>vs @createdGameNight.Opponent &mdash; @createdGameNight.Date.ToString("dd MMM yyyy")</FluentBadge>
    </div>

    <FluentProgress Min="0" Max="@totalMatches" Value="@currentMatchIndex" Style="margin-bottom: 1rem;" />

    <MatchEntryComponent
        Config="config"
        Players="players"
        Match="matchEdits[currentMatchIndex]"
        MatchNumber="currentMatchIndex + 1"
        MaximumScore="selectedSeason?.MaximumScore ?? 180" />

    @if (!string.IsNullOrEmpty(message))
    {
        <FluentMessageBar Intent="MessageIntent.Error" Style="margin-top: 0.5rem;">@message</FluentMessageBar>
    }

    <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
        @if (currentMatchIndex > 0)
        {
            <FluentButton Appearance="Appearance.Outline" @onclick="GoToPrevious">◀ Previous</FluentButton>
        }
        <FluentButton Appearance="Appearance.Accent" Style="margin-left: auto;" @onclick="SaveAndContinue" Disabled="@saving">
            @if (saving) { <FluentProgressRing Style="width: 16px; height: 16px; margin-right: 4px;" /> }
            @(currentMatchIndex == totalMatches - 1 ? "Save & Review" : "Save & Continue ▶")
        </FluentButton>
    </div>
}
else if (step == Step.Review && createdGameNight != null)
{
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
        <h3 style="margin: 0;">Review &amp; Player of the Match</h3>
        <FluentBadge>vs @createdGameNight.Opponent &mdash; @createdGameNight.Date.ToString("dd MMM yyyy")</FluentBadge>
    </div>

    <FluentProgress Min="0" Max="@totalMatches" Value="@totalMatches" Style="margin-bottom: 1rem;" />

    @foreach (var (match, idx) in createdGameNight.Matches.Select((m, i) => (m, i)))
    {
        var cfg = idx < orderedConfigs.Count ? orderedConfigs[idx] : null;
        <FluentCard Style="margin-bottom: 0.5rem; padding: 0.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                <span><strong>Match @(idx + 1)</strong> &mdash; @match.MatchTypeName</span>
                <FluentBadge Appearance="@(match.Won ? Appearance.Accent : Appearance.Neutral)">
                    @match.LegsWon &ndash; @match.LegsLost @(match.Won ? "W" : "L")
                </FluentBadge>
            </div>
            @if (match.PlayerIds.Any())
            {
                @foreach (var playerId in match.PlayerIds)
                {
                    var playerName = players.FirstOrDefault(p => p.Id == playerId)?.Name ?? playerId.ToString();
                    var stats = match.PlayerStats.FirstOrDefault(s => s.PlayerId == playerId);
                    <div style="display: flex; gap: 0.75rem; align-items: center; font-size: 0.875rem;">
                        <span style="font-weight: 600; min-width: 120px;">@playerName</span>
                        @if (stats != null)
                        {
                            <span style="color: var(--neutral-foreground-hint);">Tons: <strong>@stats.Tons</strong></span>
                            <span style="color: var(--neutral-foreground-hint);">180s: <strong>@stats.Maximums</strong></span>
                        }
                    </div>
                }
            }
        </FluentCard>
    }

    <FluentCard Style="margin-top: 1rem; padding: 0.75rem;">
        <p style="font-weight: 600; margin-bottom: 0.5rem;">Player of the Match</p>
        <PlayerSelectorComponent
            Players="players"
            SelectedPlayerIds="motmPlayerIds"
            Label="Select player(s) of the match"
            Prefix="motm" />
    </FluentCard>

    @if (!string.IsNullOrEmpty(message))
    {
        <FluentMessageBar Intent="MessageIntent.Error" Style="margin-top: 0.5rem;">@message</FluentMessageBar>
    }

    <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
        <FluentButton Appearance="Appearance.Outline" @onclick="BackToLastMatch">◀ Back to Matches</FluentButton>
        <FluentButton Appearance="Appearance.Accent" Style="margin-left: auto;" @onclick="FinalSave" Disabled="@saving">
            @if (saving) { <FluentProgressRing Style="width: 16px; height: 16px; margin-right: 4px;" /> }
            ✔ Final Save
        </FluentButton>
    </div>
}
else if (step == Step.Done)
{
    <div style="text-align: center; padding: 3rem 0;">
        <div style="font-size: 3rem;">🎯</div>
        <h3 style="margin-top: 0.5rem;">Match night saved!</h3>
        <p style="color: var(--neutral-foreground-hint);">vs @savedOpponent — all @totalMatches matches recorded.</p>
        <div style="display: flex; gap: 0.5rem; justify-content: center; margin-top: 1rem;">
            <FluentAnchor Href="/" Appearance="Appearance.Hypertext">Back to Dashboard</FluentAnchor>
            <FluentButton Appearance="Appearance.Accent" @onclick="StartNew">Enter Another Night</FluentButton>
        </div>
    </div>
}

</div>

@code {
    [Parameter, SupplyParameterFromQuery] public int? Id { get; set; }

    private enum Step { Setup, Matches, Review, Done }
    private Step step = Step.Setup;

    private List<SeasonDto> seasons = new();
    private List<PlayerDto> players = new();
    private SeasonDto? selectedSeason;
    private List<SeasonMatchConfigurationDto> orderedConfigs = new();

    // Setup fields
    private DateTime setupDate = DateTime.Today;
    private string setupOpponent = string.Empty;
    private bool setupIsHome = false;

    // After creation
    private GameNightDto? createdGameNight;
    private List<UpdateMatchDto> matchEdits = new();
    private int currentMatchIndex = 0;
    private int totalMatches => orderedConfigs.Count;

    // Review
    private List<int> motmPlayerIds = new();

    // Done
    private string savedOpponent = string.Empty;

    private string message = string.Empty;
    private bool saving = false;

    protected override async Task OnInitializedAsync()
    {
        var seasonsTask = Http.GetFromJsonAsync<List<SeasonDto>>("api/seasons");
        var playersTask = Http.GetFromJsonAsync<List<PlayerDto>>("api/players");
        await Task.WhenAll(seasonsTask, playersTask);
        seasons = seasonsTask.Result ?? new();
        players = playersTask.Result ?? new();

        if (Id.HasValue && Id > 0)
            await ResumeGameNight(Id.Value);
    }

    private async Task ResumeGameNight(int id)
    {
        createdGameNight = await Http.GetFromJsonAsync<GameNightDto>($"api/gamenights/{id}");
        if (createdGameNight == null) return;

        selectedSeason = seasons.FirstOrDefault(s => s.Id == createdGameNight.SeasonId);
        if (selectedSeason == null) return;

        orderedConfigs = selectedSeason.MatchConfigurations.OrderBy(c => c.OrderIndex).ToList();

        matchEdits = createdGameNight.Matches.Select(m => new UpdateMatchDto
        {
            LegsWon = m.LegsWon,
            LegsLost = m.LegsLost,
            PlayerIds = m.PlayerIds.ToList(),
            PlayerStats = m.PlayerStats.Select(ps => new CreatePlayerMatchStatsDto
            {
                PlayerId = ps.PlayerId,
                Tons = ps.Tons,
                Maximums = ps.Maximums
            }).ToList()
        }).ToList();

        currentMatchIndex = matchEdits.FindIndex(m => m.PlayerIds.Count == 0 && m.LegsWon == 0 && m.LegsLost == 0);
        if (currentMatchIndex < 0) currentMatchIndex = totalMatches;

        step = currentMatchIndex >= totalMatches ? Step.Review : Step.Matches;
    }

    private void OnSeasonChanged(string value)
    {
        if (int.TryParse(value, out var id) && id > 0)
        {
            selectedSeason = seasons.FirstOrDefault(s => s.Id == id);
            orderedConfigs = selectedSeason?.MatchConfigurations.OrderBy(c => c.OrderIndex).ToList() ?? new();
        }
    }

    private async Task BeginMatchNight()
    {
        if (selectedSeason == null || string.IsNullOrWhiteSpace(setupOpponent)) return;

        saving = true;
        message = string.Empty;

        var matchShells = orderedConfigs.Select(c => new CreateMatchDto
        {
            MatchTypeId = c.MatchTypeId,
            OrderIndex = c.OrderIndex
        }).ToList();

        var dto = new CreateGameNightDto
        {
            SeasonId = selectedSeason.Id,
            Date = setupDate,
            Opponent = setupOpponent,
            IsHome = setupIsHome,
            Matches = matchShells,
            ManOfTheMatchPlayerIds = new()
        };

        var response = await Http.PostAsJsonAsync("api/gamenights", dto);
        if (response.IsSuccessStatusCode)
        {
            createdGameNight = await response.Content.ReadFromJsonAsync<GameNightDto>();
            matchEdits = orderedConfigs.Select(_ => new UpdateMatchDto()).ToList();
            currentMatchIndex = 0;
            step = Step.Matches;
        }
        else
        {
            message = "Error creating match night. Please try again.";
        }
        saving = false;
    }

    private async Task SaveAndContinue()
    {
        if (createdGameNight == null) return;
        saving = true;
        message = string.Empty;

        var matchId = createdGameNight.Matches[currentMatchIndex].Id;
        var response = await Http.PatchAsJsonAsync(
            $"api/gamenights/{createdGameNight.Id}/matches/{matchId}",
            matchEdits[currentMatchIndex]);

        if (response.IsSuccessStatusCode)
        {
            currentMatchIndex++;
            if (currentMatchIndex >= totalMatches)
            {
                createdGameNight = await Http.GetFromJsonAsync<GameNightDto>($"api/gamenights/{createdGameNight.Id}");
                step = Step.Review;
            }
        }
        else
        {
            message = "Error saving match. Please try again.";
        }
        saving = false;
    }

    private void GoToPrevious()
    {
        if (currentMatchIndex > 0) currentMatchIndex--;
        message = string.Empty;
    }

    private void BackToLastMatch()
    {
        currentMatchIndex = totalMatches - 1;
        step = Step.Matches;
        message = string.Empty;
    }

    private async Task FinalSave()
    {
        if (createdGameNight == null) return;
        saving = true;
        message = string.Empty;

        var dto = new UpdateMotmDto { PlayerIds = motmPlayerIds };
        var response = await Http.PatchAsJsonAsync($"api/gamenights/{createdGameNight.Id}/motm", dto);

        if (response.IsSuccessStatusCode)
        {
            savedOpponent = createdGameNight.Opponent;
            step = Step.Done;
        }
        else
        {
            message = "Error saving. Please try again.";
        }
        saving = false;
    }

    private void StartNew()
    {
        step = Step.Setup;
        createdGameNight = null;
        matchEdits = new();
        currentMatchIndex = 0;
        setupOpponent = string.Empty;
        setupIsHome = false;
        setupDate = DateTime.Today;
        selectedSeason = null;
        orderedConfigs = new();
        motmPlayerIds = new();
        message = string.Empty;
    }
}
