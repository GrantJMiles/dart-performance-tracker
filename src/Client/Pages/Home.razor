@page "/"
@inject HttpClient Http
@using DartPerformanceTracker.Shared.DTOs

<PageTitle>Dart Tracker</PageTitle>

<div class="dashboard">
    <div class="dashboard-header">
        <h1 class="dashboard-title">Dashboard</h1>
        <div class="dashboard-selectors">
            @if (teams != null && teams.Any())
            {
                <FluentSelect TOption="string"
                              Value="@selectedTeamId.ToString()"
                              ValueChanged="@OnTeamChanged"
                              style="min-width: 150px;">
                    @foreach (var t in teams)
                    {
                        <FluentOption Value="@t.Id.ToString()">@t.Name</FluentOption>
                    }
                </FluentSelect>
            }
            @if (seasons != null && seasons.Any())
            {
                <FluentSelect TOption="string"
                              Value="@selectedSeasonId.ToString()"
                              ValueChanged="@OnSeasonChanged"
                              style="min-width: 150px;">
                    @foreach (var s in seasons)
                    {
                        <FluentOption Value="@s.Id.ToString()">@s.Name</FluentOption>
                    }
                </FluentSelect>
            }
        </div>
    </div>

    @if (incompleteNights.Any())
    {
        <FluentMessageBar Intent="MessageIntent.Warning" Style="border-radius: 8px; margin-bottom: 1rem;">
            <strong>⚠️ Incomplete match nights</strong>
            @foreach (var night in incompleteNights)
            {
                <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.25rem;">
                    <span style="font-size: 0.875rem;">vs @night.Opponent &mdash; @night.Date.ToString("dd MMM yyyy")</span>
                    <FluentAnchor Href="@($"matchday?id={night.Id}")" Appearance="Appearance.Hypertext">Continue ▶</FluentAnchor>
                </div>
            }
        </FluentMessageBar>
    }

    @if (loading)
    {
        <div class="loading-state">
            <FluentProgressRing />
            <span>Loading...</span>
        </div>
    }
    else if (teams == null || !teams.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🎯</div>
            <h3>Welcome to Dart Tracker</h3>
            <p style="color: var(--neutral-foreground-hint);">Get started by adding a season, your team, and players in settings.</p>
            <FluentAnchor Href="config" Appearance="Appearance.Hypertext">⚙️ Open Settings</FluentAnchor>
        </div>
    }
    else if (seasons == null || !seasons.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📅</div>
            <h3>No seasons yet</h3>
            <p style="color: var(--neutral-foreground-hint);">Add a season in settings to start tracking results.</p>
            <FluentAnchor Href="config" Appearance="Appearance.Hypertext">⚙️ Open Settings</FluentAnchor>
        </div>
    }
    else if (dashboard == null || dashboard.TotalGameNights == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🎯</div>
            <h3>No game nights yet</h3>
            <p style="color: var(--neutral-foreground-hint);">Record your first match night to start tracking results.</p>
            <FluentAnchor Href="matchday" Appearance="Appearance.Hypertext">📋 Enter Match Night</FluentAnchor>
        </div>
    }
    else
    {
        <div class="stat-cards">
            <div class="stat-card">
                <span class="stat-value">@dashboard.TotalGameNights</span>
                <span class="stat-label">Played</span>
            </div>
            <div class="stat-card won">
                <span class="stat-value">@dashboard.GameNightsWon</span>
                <span class="stat-label">Won</span>
            </div>
            <div class="stat-card lost">
                <span class="stat-value">@dashboard.GameNightsLost</span>
                <span class="stat-label">Lost</span>
            </div>
            <div class="stat-card drawn">
                <span class="stat-value">@dashboard.GameNightsDrawn</span>
                <span class="stat-label">Drawn</span>
            </div>
        </div>

        @if (recentNights.Any())
        {
            <div class="chart-card">
                <p class="section-title">Team Performance</p>
                <FormChartComponent Items="recentNights" />
            </div>
        }

        @* Stats Carousel *@
        <div class="stats-carousel-card mb-3">
            <div class="stats-carousel-header">
                <FluentButton Appearance="Appearance.Stealth" @onclick="PrevSlide" title="Previous">&#8249;</FluentButton>
                <div class="stats-carousel-title">
                    @slideTitle
                    <div class="carousel-dots mt-1">
                        @for (int i = 0; i < 4; i++)
                        {
                            var idx = i;
                            <span class="carousel-dot @(currentSlide == idx ? "active" : "")" @onclick="() => currentSlide = idx"></span>
                        }
                    </div>
                </div>
                <FluentButton Appearance="Appearance.Stealth" @onclick="NextSlide" title="Next">&#8250;</FluentButton>
            </div>
            <div class="stats-carousel-body">
                @if (currentSlide == 0)
                {
                    var last5 = dashboard.GameNightSummaries.OrderByDescending(g => g.Date).Take(5).OrderBy(g => g.Date).ToList();
                    @if (last5.Any())
                    {
                        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center;">
                            @foreach (var night in last5)
                            {
                                var result = night.Won ? "W" : night.MatchesWon == night.MatchesLost ? "D" : "L";
                                var formClass = result == "W" ? "badge-won" : result == "D" ? "badge-drawn" : "badge-lost";
                                <div class="form-badge-wrapper">
                                    <span class="result-badge form-result-badge @formClass">@result</span>
                                    <div class="form-badge-tooltip">
                                        <span style="font-weight: 600;">@result (@night.MatchesWon–@night.MatchesLost)</span>
                                        <span>@night.Date.ToString("dd MMM")</span>
                                        <span>vs @night.Opponent</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="carousel-empty-state">
                            <span class="carousel-empty-icon">📅</span>
                            <p>No results recorded yet.</p>
                        </div>
                    }
                }
                else if (currentSlide == 1)
                {
                    @if (insightsLoading)
                    {
                        <div class="carousel-empty-state"><FluentProgressRing /></div>
                    }
                    else if (insights?.SinglesMvp != null)
                    {
                        <div class="mvp-display">
                            <div class="mvp-trophy">🏆</div>
                            <div class="mvp-player-name">@insights.SinglesMvp.PlayerName</div>
                            <div class="mvp-stat-primary">@insights.SinglesMvp.WinPercentage% win rate</div>
                            <div class="mvp-stat-secondary">@insights.SinglesMvp.MatchesWon wins from @insights.SinglesMvp.MatchesPlayed singles games</div>
                        </div>
                    }
                    else
                    {
                        <div class="carousel-empty-state">
                            <span class="carousel-empty-icon">🎯</span>
                            <p>No Singles MVP yet.</p>
                            <p class="carousel-empty-hint">Players need at least 5 singles games to qualify.</p>
                        </div>
                    }
                }
                else if (currentSlide == 2)
                {
                    @if (insightsLoading)
                    {
                        <div class="carousel-empty-state"><FluentProgressRing /></div>
                    }
                    else if (insights?.SeasonMvp != null)
                    {
                        <div class="mvp-display">
                            <div class="mvp-trophy">🌟</div>
                            <div class="mvp-player-name">@insights.SeasonMvp.PlayerName</div>
                            <div class="mvp-stat-primary">@insights.SeasonMvp.MatchesWon wins this season</div>
                            <div class="mvp-stat-secondary">@insights.SeasonMvp.WinPercentage% win rate across @insights.SeasonMvp.MatchesPlayed singles &amp; pairs games</div>
                        </div>
                    }
                    else
                    {
                        <div class="carousel-empty-state">
                            <span class="carousel-empty-icon">🌟</span>
                            <p>No Season MVP data yet.</p>
                            <p class="carousel-empty-hint">Record singles and pairs results to see the season leader.</p>
                        </div>
                    }
                }
                else
                {
                    @if (insightsLoading)
                    {
                        <div class="carousel-empty-state"><FluentProgressRing /></div>
                    }
                    else if (insights?.PairsMvp != null)
                    {
                        <div class="mvp-display">
                            <div class="mvp-trophy">🤝</div>
                            <div class="mvp-player-name">@insights.PairsMvp.Player1Name &amp; @insights.PairsMvp.Player2Name</div>
                            <div class="mvp-stat-primary">@insights.PairsMvp.MatchesWon wins together</div>
                            <div class="mvp-stat-secondary">@insights.PairsMvp.MatchesPlayed pairs games played</div>
                        </div>
                    }
                    else
                    {
                        <div class="carousel-empty-state">
                            <span class="carousel-empty-icon">🤝</span>
                            <p>No Pairs MVP data yet.</p>
                            <p class="carousel-empty-hint">Record pairs match results to find your best duo.</p>
                        </div>
                    }
                }
            </div>
        </div>

        @if (dashboard.GameNightSummaries.Any())
        {
            <div class="results-card">
                <p class="section-title">Game Nights</p>
                <div class="results-list">
                    @foreach (var night in dashboard.GameNightSummaries.OrderByDescending(g => g.Date))
                    {
                        var isWon = night.Won;
                        var isDrawn = !night.Won && night.MatchesWon == night.MatchesLost;
                        <div class="result-row" style="cursor: pointer;" @onclick="() => OpenGameNightDetail(night.GameNightId)">
                            <span class="result-date">@night.Date.ToString("dd MMM")</span>
                            <span class="result-opponent">vs @night.Opponent @(night.IsHome ? "🏠" : "✈️")</span>
                            <span class="result-score">@night.MatchesWon–@night.MatchesLost</span>
                            <span class="result-badge @(isWon ? "badge-won" : isDrawn ? "badge-drawn" : "badge-lost")">
                                @(isWon ? "W" : isDrawn ? "D" : "L")
                            </span>
                        </div>
                    }
                </div>
            </div>
        }

        <PlayerAccordionComponent Players="playerStats" MaximumScore="@(seasons?.FirstOrDefault(s => s.Id == selectedSeasonId)?.MaximumScore ?? 180)" />
    }
</div>

<GameNightDetailModal GameNight="selectedGameNight"
                      Visible="modalVisible"
                      MotmNames="motmNames"
                      OnClose="CloseModal" />

@code {
    private List<TeamDto>? teams;
    private List<SeasonDto>? seasons;
    private int selectedTeamId;
    private int selectedSeasonId;
    private TeamDashboardDto? dashboard;
    private DashboardInsightsDto? insights;
    private List<TeamPlayerSeasonStatsDto>? playerStats;
    private bool loading = true;
    private bool insightsLoading = false;
    private List<GameNightDto> incompleteNights = new();

    private GameNightDto? selectedGameNight;
    private bool modalVisible;
    private List<string> motmNames = new();

    private int currentSlide = 0;
    private static readonly string[] SlideTitles = ["Team Form (Last 5)", "Singles MVP", "Season MVP", "Pairs MVPs"];
    private string slideTitle => SlideTitles[currentSlide];

    private void PrevSlide() => currentSlide = (currentSlide + 3) % 4;
    private void NextSlide() => currentSlide = (currentSlide + 1) % 4;

    private List<GameNightSummaryDto> recentNights =>
        dashboard?.GameNightSummaries
            .OrderBy(g => g.Date)
            .ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        var teamsTask = Http.GetFromJsonAsync<List<TeamDto>>("api/teams");
        var seasonsTask = Http.GetFromJsonAsync<List<SeasonDto>>("api/seasons");
        var incompleteTask = Http.GetFromJsonAsync<List<GameNightDto>>("api/gamenights?incomplete=true");
        await Task.WhenAll(teamsTask, seasonsTask, incompleteTask);

        teams = teamsTask.Result;
        seasons = seasonsTask.Result;
        incompleteNights = incompleteTask.Result ?? new();

        if (teams != null && teams.Any())
            selectedTeamId = teams.First().Id;

        if (seasons != null && seasons.Any())
            selectedSeasonId = seasons.First().Id;

        await LoadDashboard();
    }

    private async Task OnTeamChanged(string? value)
    {
        if (int.TryParse(value, out var id) && id > 0)
        {
            selectedTeamId = id;
            await LoadDashboard();
        }
    }

    private async Task OnSeasonChanged(string? value)
    {
        if (int.TryParse(value, out var id) && id > 0)
        {
            selectedSeasonId = id;
            await LoadDashboard();
        }
    }

    private async Task LoadDashboard()
    {
        loading = true;
        dashboard = null;
        insights = null;
        playerStats = null;
        currentSlide = 0;
        StateHasChanged();
        try
        {
            if (selectedTeamId > 0 && selectedSeasonId > 0)
            {
                var dashboardTask = Http.GetFromJsonAsync<TeamDashboardDto>(
                    $"api/dashboard/team/{selectedTeamId}/season/{selectedSeasonId}");
                var insightsTask = Http.GetFromJsonAsync<DashboardInsightsDto>(
                    $"api/dashboard/insights/{selectedTeamId}/season/{selectedSeasonId}");
                var playerStatsTask = Http.GetFromJsonAsync<List<TeamPlayerSeasonStatsDto>>(
                    $"api/dashboard/team/{selectedTeamId}/season/{selectedSeasonId}/players");
                await Task.WhenAll(dashboardTask, insightsTask, playerStatsTask);
                dashboard = await dashboardTask;
                insights = await insightsTask;
                playerStats = await playerStatsTask;
            }
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OpenGameNightDetail(int gameNightId)
    {
        var gn = await Http.GetFromJsonAsync<GameNightDto>($"api/gamenights/{gameNightId}");
        if (gn == null) return;

        selectedGameNight = gn;
        motmNames = BuildMotmNames(gn);
        modalVisible = true;
    }

    private List<string> BuildMotmNames(GameNightDto gn)
    {
        var allPlayers = gn.Matches
            .SelectMany(m => m.PlayerStats)
            .Where(ps => !string.IsNullOrEmpty(ps.PlayerName))
            .GroupBy(ps => ps.PlayerId)
            .ToDictionary(g => g.Key, g => g.First().PlayerName);

        return gn.ManOfTheMatchPlayerIds
            .Select(id => allPlayers.TryGetValue(id, out var name) ? name : $"Player {id}")
            .ToList();
    }

    private void CloseModal()
    {
        modalVisible = false;
        selectedGameNight = null;
    }
}
