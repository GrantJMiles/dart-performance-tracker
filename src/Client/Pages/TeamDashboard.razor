@page "/dashboard/team/{SeasonId:int}"
@using DartPerformanceTracker.Shared.DTOs
@inject HttpClient Http

<h3>Team Dashboard</h3>

@if (dashboard == null)
{
    <FluentProgressRing />
}
else
{
    <h4>@dashboard.SeasonName</h4>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1rem;">
        <FluentCard><div><strong>Game Nights:</strong> @dashboard.TotalGameNights</div></FluentCard>
        <FluentCard><div><strong>Won:</strong> @dashboard.GameNightsWon</div></FluentCard>
        <FluentCard><div><strong>Lost:</strong> @dashboard.GameNightsLost</div></FluentCard>
        <FluentCard><div><strong>Drawn:</strong> @dashboard.GameNightsDrawn</div></FluentCard>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem;">
        <FluentCard><div><strong>Matches Played:</strong> @dashboard.TotalMatchesPlayed</div></FluentCard>
        <FluentCard><div><strong>Matches Won:</strong> @dashboard.TotalMatchesWon</div></FluentCard>
        <FluentCard><div><strong>Matches Lost:</strong> @dashboard.TotalMatchesLost</div></FluentCard>
    </div>
    @if (dashboard.LastFiveForm.Count > 0)
    {
        <div style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
            <strong>Last @dashboard.LastFiveForm.Count Form:</strong>
            @foreach (var result in dashboard.LastFiveForm)
            {
                <FluentBadge Appearance="@(result == "W" ? Appearance.Accent : Appearance.Neutral)">@result</FluentBadge>
            }
        </div>
    }
    <StatsSummaryComponent Label="Game Night Results" Items="gameNightItems" />
}

@code {
    [Parameter] public int SeasonId { get; set; }
    private TeamDashboardDto? dashboard;

    private List<string> gameNightItems => dashboard?.GameNightSummaries
        .Select(s => $"{s.Date:dd/MM/yy} vs {s.Opponent}: {(s.Won ? "W" : "L")} ({s.MatchesWon}-{s.MatchesLost})")
        .ToList() ?? new();

    protected override async Task OnParametersSetAsync()
    {
        dashboard = await Http.GetFromJsonAsync<TeamDashboardDto>($"api/dashboard/team/{SeasonId}");
    }
}
