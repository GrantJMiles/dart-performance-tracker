@page "/dashboard/team/{SeasonId:int}"
@using DartPerformanceTracker.Shared.DTOs
@inject HttpClient Http

<h3>Team Dashboard</h3>

@if (dashboard == null)
{
    <p>Loading...</p>
}
else
{
    <h4>@dashboard.SeasonName</h4>
    <div class="row mb-3">
        <div class="col"><strong>Game Nights:</strong> @dashboard.TotalGameNights</div>
        <div class="col"><strong>Won:</strong> @dashboard.GameNightsWon</div>
        <div class="col"><strong>Lost:</strong> @dashboard.GameNightsLost</div>
        <div class="col"><strong>Drawn:</strong> @dashboard.GameNightsDrawn</div>
    </div>
    <div class="row mb-3">
        <div class="col"><strong>Matches Played:</strong> @dashboard.TotalMatchesPlayed</div>
        <div class="col"><strong>Matches Won:</strong> @dashboard.TotalMatchesWon</div>
        <div class="col"><strong>Matches Lost:</strong> @dashboard.TotalMatchesLost</div>
    </div>
    @if (dashboard.LastFiveForm.Count > 0)
    {
        <div class="row mb-3">
            <div class="col">
                <strong>Last @dashboard.LastFiveForm.Count Form:</strong>
                @foreach (var result in dashboard.LastFiveForm.AsEnumerable().Reverse())
                {
                    <span class="badge me-1 @(result == "W" ? "bg-success" : result == "L" ? "bg-danger" : "bg-secondary")">@result</span>
                }
            </div>
        </div>
    }
    <StatsSummaryComponent Label="Game Night Results" Items="gameNightItems" />
}

@code {
    [Parameter] public int SeasonId { get; set; }
    private TeamDashboardDto? dashboard;

    private List<string> gameNightItems => dashboard?.GameNightSummaries
        .Select(s => $"{s.Date:dd/MM/yy} vs {s.Opponent}: {(s.Won ? "W" : "L")} ({s.MatchesWon}-{s.MatchesLost})")
        .ToList() ?? new();

    protected override async Task OnParametersSetAsync()
    {
        dashboard = await Http.GetFromJsonAsync<TeamDashboardDto>($"api/dashboard/team/{SeasonId}");
    }
}
