@page "/dashboard/player/{PlayerId:int}"
@using DartPerformanceTracker.Shared.DTOs
@inject HttpClient Http

<h3>Player Dashboard</h3>

@if (dashboard == null)
{
    <FluentProgressRing />
}
else
{
    <h4>@dashboard.PlayerName - @dashboard.TeamName</h4>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem;">
        <FluentCard><div><strong>Matches Played:</strong> @dashboard.MatchesPlayed</div></FluentCard>
        <FluentCard><div><strong>Won:</strong> @dashboard.MatchesWon</div></FluentCard>
        <FluentCard><div><strong>Lost:</strong> @dashboard.MatchesLost</div></FluentCard>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem;">
        <FluentCard><div><strong>Total Tons:</strong> @dashboard.TotalTons</div></FluentCard>
        <FluentCard><div><strong>Total Maximums:</strong> @dashboard.TotalMaximums</div></FluentCard>
        <FluentCard><div><strong>Man of the Match:</strong> @dashboard.ManOfTheMatchCount</div></FluentCard>
    </div>
    @if (dashboard.TopTeammate != null)
    {
        <div style="margin-bottom: 1rem;">
            <strong>Top Teammate:</strong> @dashboard.TopTeammate.PlayerName
            (@dashboard.TopTeammate.GamesPlayedTogether played, @dashboard.TopTeammate.WinsTogether wins together)
        </div>
    }
    <StatsSummaryComponent Label="Recent Matches" Items="recentMatchItems" />
}

@code {
    [Parameter] public int PlayerId { get; set; }
    private PlayerDashboardDto? dashboard;

    private List<string> recentMatchItems => dashboard?.RecentMatches
        .Select(m => $"{m.Date:dd/MM/yy} vs {m.Opponent} [{m.MatchTypeName}]: {(m.Won ? "W" : "L")} | Tons: {m.Tons} | 180s: {m.Maximums}")
        .ToList() ?? new();

    protected override async Task OnParametersSetAsync()
    {
        dashboard = await Http.GetFromJsonAsync<PlayerDashboardDto>($"api/dashboard/player/{PlayerId}");
    }
}
