@page "/config"

<PageTitle>Configuration – Dart Tracker</PageTitle>

<div class="config-page">
    <h1 class="page-title">⚙️ Configuration</h1>

    <FluentTabs ActiveTabId="@activeTab" ActiveTabIdChanged="@(id => SetTab(id))">
        <FluentTab Id="seasons">📅 Seasons</FluentTab>
        <FluentTab Id="teams">👥 Teams</FluentTab>
        <FluentTab Id="players">👤 Players</FluentTab>
    </FluentTabs>

    <div class="config-section">

        @if (activeTab == "seasons")
        {
            <p class="section-title">Seasons</p>

            @if (seasons == null)
            {
                <FluentProgressRing />
            }
            else if (seasons.Any())
            {
                <table class="config-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Max Score</th>
                            <th>Matches</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var season in seasons)
                        {
                            <tr>
                                <td><strong>@season.Name</strong></td>
                                <td>@season.StartDate.ToShortDateString()</td>
                                <td>@season.EndDate.ToShortDateString()</td>
                                <td>@season.MaximumScore</td>
                                <td style="color: var(--neutral-foreground-hint); font-size: 0.875rem;">@season.MatchConfigurations.Count slots</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color: var(--neutral-foreground-hint); font-size: 0.875rem;">No seasons yet. Add one below.</p>
            }

            <FluentDivider Style="margin: 1rem 0;" />
            <p class="section-title">Add Season</p>
            <EditForm Model="newSeason" OnValidSubmit="AddSeason">
                <DataAnnotationsValidator />
                <div class="config-form-row">
                    <div>
                        <FluentTextField @bind-Value="newSeason.Name" Label="Name" Placeholder="e.g. 2025/26" style="width: 100%;" />
                    </div>
                    <div>
                        <label class="form-label">Start Date</label>
                        <FluentDatePicker Value="@((DateTime?)newSeason.StartDate)"
                                          ValueChanged="@(v => newSeason.StartDate = v ?? DateTime.Today)"
                                          style="width: 100%;" />
                    </div>
                    <div>
                        <label class="form-label">End Date</label>
                        <FluentDatePicker Value="@((DateTime?)newSeason.EndDate)"
                                          ValueChanged="@(v => newSeason.EndDate = v ?? DateTime.Today)"
                                          style="width: 100%;" />
                    </div>
                    <div>
                        <FluentNumberField @bind-Value="newSeason.MaximumScore" Label="Maximum Score" style="width: 100%;" />
                        <div style="font-size: 0.8rem; color: var(--neutral-foreground-hint);">e.g. 180 (standard), 170 (cricket/bull)</div>
                    </div>
                </div>

                <div style="margin-top: 1rem;">
                    <label class="form-label" style="font-weight: 600;">Match Format</label>
                    <p style="color: var(--neutral-foreground-hint); font-size: 0.875rem; margin-bottom: 0.5rem;">Build the playing order for this season. Each entry = one match on the night.</p>
                    @if (matchTypes != null && matchTypes.Any())
                    {
                        <div style="display: flex; gap: 0.5rem; margin-bottom: 0.5rem; align-items: flex-end;">
                            <FluentSelect TOption="string" Value="@selectedMatchTypeId.ToString()"
                                          ValueChanged="@(v => selectedMatchTypeId = int.TryParse(v, out var id) ? id : 0)"
                                          style="max-width: 280px;">
                                <FluentOption Value="@("0")">-- Select Match Type --</FluentOption>
                                @foreach (var mt in matchTypes)
                                {
                                    <FluentOption Value="@mt.Id.ToString()">@mt.Name (@mt.PlayersPerSide v @mt.PlayersPerSide)</FluentOption>
                                }
                            </FluentSelect>
                            <FluentButton Appearance="Appearance.Outline" @onclick="AddMatchSlot"
                                          Disabled="@(selectedMatchTypeId == 0)">
                                + Add
                            </FluentButton>
                        </div>

                        @if (newSeason.MatchConfigurations.Any())
                        {
                            <div style="max-width: 420px; margin-bottom: 1rem;">
                                @for (int i = 0; i < newSeason.MatchConfigurations.Count; i++)
                                {
                                    var idx = i;
                                    var mtName = matchTypes.FirstOrDefault(mt => mt.Id == newSeason.MatchConfigurations[idx].MatchTypeId)?.Name ?? "Unknown";
                                    <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.25rem 0.5rem; border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; margin-bottom: 4px;">
                                        <span style="color: var(--neutral-foreground-hint); font-size: 0.875rem; min-width: 24px;">@(idx + 1).</span>
                                        <span style="flex-grow: 1; font-size: 0.875rem;">@mtName</span>
                                        <FluentButton Appearance="Appearance.Stealth" @onclick="() => MoveMatchSlotUp(idx)"
                                                      Disabled="@(idx == 0)" title="Move up" style="padding: 0 4px;">▲</FluentButton>
                                        <FluentButton Appearance="Appearance.Stealth" @onclick="() => MoveMatchSlotDown(idx)"
                                                      Disabled="@(idx == newSeason.MatchConfigurations.Count - 1)" title="Move down" style="padding: 0 4px;">▼</FluentButton>
                                        <FluentButton Appearance="Appearance.Stealth" @onclick="() => RemoveMatchSlot(idx)" title="Remove" style="padding: 0 4px; color: var(--error);">✕</FluentButton>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p style="color: var(--neutral-foreground-hint); font-size: 0.875rem;">No matches added yet.</p>
                        }
                    }
                    else
                    {
                        <p style="color: var(--neutral-foreground-hint); font-size: 0.875rem;">Loading match types...</p>
                    }
                </div>

                <div style="margin-top: 0.5rem;">
                    <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent">Add Season</FluentButton>
                </div>
            </EditForm>
        }

        else if (activeTab == "teams")
        {
            <p class="section-title">Teams</p>

            @if (teams == null)
            {
                <FluentProgressRing />
            }
            else if (teams.Any())
            {
                <table class="config-table">
                    <thead>
                        <tr><th>Name</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var team in teams)
                        {
                            <tr><td><strong>@team.Name</strong></td></tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color: var(--neutral-foreground-hint); font-size: 0.875rem;">No teams yet. Add one below.</p>
            }

            <FluentDivider Style="margin: 1rem 0;" />
            <p class="section-title">Add Team</p>
            <EditForm Model="newTeam" OnValidSubmit="AddTeam">
                <DataAnnotationsValidator />
                <div class="config-form-row">
                    <div>
                        <FluentTextField @bind-Value="newTeam.Name" Label="Name" Placeholder="e.g. The Arrows" style="width: 100%;" />
                    </div>
                    <div style="display: flex; align-items: flex-end;">
                        <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" style="width: 100%;">Add Team</FluentButton>
                    </div>
                </div>
            </EditForm>
        }

        else if (activeTab == "players")
        {
            <p class="section-title">Players</p>

            @if (players == null)
            {
                <FluentProgressRing />
            }
            else if (players.Any())
            {
                <table class="config-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Team</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var player in players)
                        {
                            <tr>
                                <td><strong>@player.Name</strong></td>
                                <td>@player.TeamName</td>
                                <td>
                                    @if (player.IsActive)
                                    {
                                        <FluentBadge Appearance="Appearance.Accent">Active</FluentBadge>
                                    }
                                    else
                                    {
                                        <FluentBadge>Inactive</FluentBadge>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color: var(--neutral-foreground-hint); font-size: 0.875rem;">No players yet. Add one below.</p>
            }

            <FluentDivider Style="margin: 1rem 0;" />
            <p class="section-title">Add Player</p>
            <EditForm Model="newPlayer" OnValidSubmit="AddPlayer">
                <DataAnnotationsValidator />
                <div class="config-form-row">
                    <div>
                        <FluentTextField @bind-Value="newPlayer.Name" Label="Name" Placeholder="Player name" style="width: 100%;" />
                    </div>
                    <div>
                        <label class="form-label">Team</label>
                        <FluentSelect TOption="string" Value="@newPlayer.TeamId.ToString()"
                                      ValueChanged="@(v => newPlayer.TeamId = int.TryParse(v, out var id) ? id : 0)"
                                      style="width: 100%;">
                            <FluentOption Value="@("0")">-- Select Team --</FluentOption>
                            @foreach (var team in teams ?? new List<TeamDto>())
                            {
                                <FluentOption Value="@team.Id.ToString()">@team.Name</FluentOption>
                            }
                        </FluentSelect>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.5rem; padding-top: 1.5rem;">
                        <FluentCheckbox @bind-Value="newPlayer.IsActive" Label="Active" />
                    </div>
                    <div style="display: flex; align-items: flex-end;">
                        <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" style="width: 100%;">Add Player</FluentButton>
                    </div>
                </div>
            </EditForm>
        }

    </div>
</div>

@code {
    private string activeTab = "seasons";

    private List<SeasonDto>? seasons;
    private List<TeamDto>? teams;
    private List<PlayerDto>? players;
    private List<MatchTypeDto>? matchTypes;

    private CreateSeasonDto newSeason = new() { StartDate = DateTime.Today, EndDate = DateTime.Today.AddMonths(6) };
    private CreateTeamDto newTeam = new();
    private CreatePlayerDto newPlayer = new() { IsActive = true };
    private int selectedMatchTypeId = 0;

    [Inject] private HttpClient Http { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadSeasons(), LoadTeams(), LoadPlayers(), LoadMatchTypes());
    }

    private void SetTab(string? tab)
    {
        if (tab != null) activeTab = tab;
    }

    private async Task LoadSeasons() =>
        seasons = await Http.GetFromJsonAsync<List<SeasonDto>>("api/seasons");

    private async Task LoadTeams() =>
        teams = await Http.GetFromJsonAsync<List<TeamDto>>("api/teams");

    private async Task LoadPlayers() =>
        players = await Http.GetFromJsonAsync<List<PlayerDto>>("api/players");

    private async Task LoadMatchTypes() =>
        matchTypes = await Http.GetFromJsonAsync<List<MatchTypeDto>>("api/matchtypes");

    // --- Match format builder ---

    private void AddMatchSlot()
    {
        if (selectedMatchTypeId == 0) return;
        newSeason.MatchConfigurations.Add(new CreateSeasonMatchConfigurationDto
        {
            MatchTypeId = selectedMatchTypeId,
            OrderIndex = newSeason.MatchConfigurations.Count
        });
        RenumberMatchSlots();
    }

    private void MoveMatchSlotUp(int index)
    {
        if (index <= 0) return;
        var item = newSeason.MatchConfigurations[index];
        newSeason.MatchConfigurations.RemoveAt(index);
        newSeason.MatchConfigurations.Insert(index - 1, item);
        RenumberMatchSlots();
    }

    private void MoveMatchSlotDown(int index)
    {
        if (index >= newSeason.MatchConfigurations.Count - 1) return;
        var item = newSeason.MatchConfigurations[index];
        newSeason.MatchConfigurations.RemoveAt(index);
        newSeason.MatchConfigurations.Insert(index + 1, item);
        RenumberMatchSlots();
    }

    private void RemoveMatchSlot(int index)
    {
        newSeason.MatchConfigurations.RemoveAt(index);
        RenumberMatchSlots();
    }

    private void RenumberMatchSlots()
    {
        for (int i = 0; i < newSeason.MatchConfigurations.Count; i++)
            newSeason.MatchConfigurations[i].OrderIndex = i;
    }

    // --- CRUD handlers ---

    private async Task AddSeason()
    {
        var response = await Http.PostAsJsonAsync("api/seasons", newSeason);
        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<SeasonDto>();
            seasons?.Add(created!);
            newSeason = new CreateSeasonDto { StartDate = DateTime.Today, EndDate = DateTime.Today.AddMonths(6) };
            selectedMatchTypeId = 0;
        }
    }

    private async Task AddTeam()
    {
        var response = await Http.PostAsJsonAsync("api/teams", newTeam);
        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<TeamDto>();
            teams?.Add(created!);
            newTeam = new CreateTeamDto();
        }
    }

    private async Task AddPlayer()
    {
        var response = await Http.PostAsJsonAsync("api/players", newPlayer);
        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<PlayerDto>();
            players?.Add(created!);
            newPlayer = new CreatePlayerDto { IsActive = true };
        }
    }
}
