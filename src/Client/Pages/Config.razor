@page "/config"

<PageTitle>Configuration – Dart Tracker</PageTitle>

<div class="config-page">
    <h1 class="page-title">
        <i class="bi bi-gear-fill me-2"></i>Configuration
    </h1>

    <ul class="nav nav-tabs mb-0">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "seasons" ? "active" : "")" @onclick='() => SetTab("seasons")'>
                <i class="bi bi-calendar3 me-1"></i>Seasons
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "teams" ? "active" : "")" @onclick='() => SetTab("teams")'>
                <i class="bi bi-people-fill me-1"></i>Teams
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "players" ? "active" : "")" @onclick='() => SetTab("players")'>
                <i class="bi bi-person-fill me-1"></i>Players
            </button>
        </li>
    </ul>

    <div class="config-section">

        @if (activeTab == "seasons")
        {
            <p class="section-title">Seasons</p>

            @if (seasons == null)
            {
                <p class="text-muted">Loading...</p>
            }
            else if (seasons.Any())
            {
                <table class="config-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Max Score</th>
                            <th>Matches</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var season in seasons)
                        {
                            <tr>
                                <td><strong>@season.Name</strong></td>
                                <td>@season.StartDate.ToShortDateString()</td>
                                <td>@season.EndDate.ToShortDateString()</td>
                                <td>@season.MaximumScore</td>
                                <td class="text-muted small">@season.MatchConfigurations.Count slots</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted small">No seasons yet. Add one below.</p>
            }

            <hr class="my-3" />
            <p class="section-title">Add Season</p>
            <EditForm Model="newSeason" OnValidSubmit="AddSeason">
                <DataAnnotationsValidator />
                <div class="config-form-row">
                    <div>
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="newSeason.Name" placeholder="e.g. 2025/26" />
                    </div>
                    <div>
                        <label class="form-label">Start Date</label>
                        <InputDate class="form-control" @bind-Value="newSeason.StartDate" />
                    </div>
                    <div>
                        <label class="form-label">End Date</label>
                        <InputDate class="form-control" @bind-Value="newSeason.EndDate" />
                    </div>
                    <div>
                        <label class="form-label">Maximum Score</label>
                        <InputNumber class="form-control" @bind-Value="newSeason.MaximumScore" />
                        <div class="form-text">e.g. 180 (standard), 170 (cricket/bull)</div>
                    </div>
                </div>

                <div class="mt-3">
                    <label class="form-label fw-semibold">Match Format</label>
                    <p class="text-muted small mb-2">Build the playing order for this season. Each entry = one match on the night.</p>
                    @if (matchTypes != null && matchTypes.Any())
                    {
                        <div class="d-flex gap-2 mb-2">
                            <select class="form-select form-select-sm" style="max-width: 260px;" @bind="selectedMatchTypeId">
                                <option value="0">-- Select Match Type --</option>
                                @foreach (var mt in matchTypes)
                                {
                                    <option value="@mt.Id">@mt.Name (@mt.PlayersPerSide v @mt.PlayersPerSide)</option>
                                }
                            </select>
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="AddMatchSlot"
                                    disabled="@(selectedMatchTypeId == 0)">
                                + Add
                            </button>
                        </div>

                        @if (newSeason.MatchConfigurations.Any())
                        {
                            <div class="list-group mb-3" style="max-width: 420px;">
                                @for (int i = 0; i < newSeason.MatchConfigurations.Count; i++)
                                {
                                    var idx = i;
                                    var mtName = matchTypes.FirstOrDefault(mt => mt.Id == newSeason.MatchConfigurations[idx].MatchTypeId)?.Name ?? "Unknown";
                                    <div class="list-group-item d-flex align-items-center gap-2 py-1 px-2">
                                        <span class="text-muted small" style="min-width: 24px;">@(idx + 1).</span>
                                        <span class="flex-grow-1 small">@mtName</span>
                                        <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1"
                                                @onclick="() => MoveMatchSlotUp(idx)"
                                                disabled="@(idx == 0)" title="Move up">▲</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1"
                                                @onclick="() => MoveMatchSlotDown(idx)"
                                                disabled="@(idx == newSeason.MatchConfigurations.Count - 1)" title="Move down">▼</button>
                                        <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1"
                                                @onclick="() => RemoveMatchSlot(idx)" title="Remove">✕</button>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small">No matches added yet.</p>
                        }
                    }
                    else
                    {
                        <p class="text-muted small">Loading match types...</p>
                    }
                </div>

                <div class="mt-2">
                    <button type="submit" class="btn btn-primary">Add Season</button>
                </div>
            </EditForm>
        }

        else if (activeTab == "teams")
        {
            <p class="section-title">Teams</p>

            @if (teams == null)
            {
                <p class="text-muted">Loading...</p>
            }
            else if (teams.Any())
            {
                <table class="config-table">
                    <thead>
                        <tr><th>Name</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var team in teams)
                        {
                            <tr><td><strong>@team.Name</strong></td></tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted small">No teams yet. Add one below.</p>
            }

            <hr class="my-3" />
            <p class="section-title">Add Team</p>
            <EditForm Model="newTeam" OnValidSubmit="AddTeam">
                <DataAnnotationsValidator />
                <div class="config-form-row">
                    <div>
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="newTeam.Name" placeholder="e.g. The Arrows" />
                    </div>
                    <div class="d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Add Team</button>
                    </div>
                </div>
            </EditForm>
        }

        else if (activeTab == "players")
        {
            <p class="section-title">Players</p>

            @if (players == null)
            {
                <p class="text-muted">Loading...</p>
            }
            else if (players.Any())
            {
                <table class="config-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Team</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var player in players)
                        {
                            <tr>
                                <td><strong>@player.Name</strong></td>
                                <td>@player.TeamName</td>
                                <td>
                                    @if (player.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted small">No players yet. Add one below.</p>
            }

            <hr class="my-3" />
            <p class="section-title">Add Player</p>
            <EditForm Model="newPlayer" OnValidSubmit="AddPlayer">
                <DataAnnotationsValidator />
                <div class="config-form-row">
                    <div>
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="newPlayer.Name" placeholder="Player name" />
                    </div>
                    <div>
                        <label class="form-label">Team</label>
                        <InputSelect class="form-control" @bind-Value="newPlayer.TeamId">
                            <option value="0">-- Select Team --</option>
                            @foreach (var team in teams ?? new List<TeamDto>())
                            {
                                <option value="@team.Id">@team.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="d-flex align-items-center gap-2" style="padding-top: 1.5rem;">
                        <InputCheckbox class="form-check-input mt-0" @bind-Value="newPlayer.IsActive" id="playerActive" />
                        <label class="form-check-label" for="playerActive">Active</label>
                    </div>
                    <div class="d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Add Player</button>
                    </div>
                </div>
            </EditForm>
        }

    </div>
</div>

@code {
    private string activeTab = "seasons";

    private List<SeasonDto>? seasons;
    private List<TeamDto>? teams;
    private List<PlayerDto>? players;
    private List<MatchTypeDto>? matchTypes;

    private CreateSeasonDto newSeason = new() { StartDate = DateTime.Today, EndDate = DateTime.Today.AddMonths(6) };
    private CreateTeamDto newTeam = new();
    private CreatePlayerDto newPlayer = new() { IsActive = true };
    private int selectedMatchTypeId = 0;

    [Inject] private HttpClient Http { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadSeasons(), LoadTeams(), LoadPlayers(), LoadMatchTypes());
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
    }

    private async Task LoadSeasons() =>
        seasons = await Http.GetFromJsonAsync<List<SeasonDto>>("api/seasons");

    private async Task LoadTeams() =>
        teams = await Http.GetFromJsonAsync<List<TeamDto>>("api/teams");

    private async Task LoadPlayers() =>
        players = await Http.GetFromJsonAsync<List<PlayerDto>>("api/players");

    private async Task LoadMatchTypes() =>
        matchTypes = await Http.GetFromJsonAsync<List<MatchTypeDto>>("api/matchtypes");

    // --- Match format builder ---

    private void AddMatchSlot()
    {
        if (selectedMatchTypeId == 0) return;
        newSeason.MatchConfigurations.Add(new CreateSeasonMatchConfigurationDto
        {
            MatchTypeId = selectedMatchTypeId,
            OrderIndex = newSeason.MatchConfigurations.Count
        });
        RenumberMatchSlots();
    }

    private void MoveMatchSlotUp(int index)
    {
        if (index <= 0) return;
        var item = newSeason.MatchConfigurations[index];
        newSeason.MatchConfigurations.RemoveAt(index);
        newSeason.MatchConfigurations.Insert(index - 1, item);
        RenumberMatchSlots();
    }

    private void MoveMatchSlotDown(int index)
    {
        if (index >= newSeason.MatchConfigurations.Count - 1) return;
        var item = newSeason.MatchConfigurations[index];
        newSeason.MatchConfigurations.RemoveAt(index);
        newSeason.MatchConfigurations.Insert(index + 1, item);
        RenumberMatchSlots();
    }

    private void RemoveMatchSlot(int index)
    {
        newSeason.MatchConfigurations.RemoveAt(index);
        RenumberMatchSlots();
    }

    private void RenumberMatchSlots()
    {
        for (int i = 0; i < newSeason.MatchConfigurations.Count; i++)
            newSeason.MatchConfigurations[i].OrderIndex = i;
    }

    // --- CRUD handlers ---

    private async Task AddSeason()
    {
        var response = await Http.PostAsJsonAsync("api/seasons", newSeason);
        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<SeasonDto>();
            seasons?.Add(created!);
            newSeason = new CreateSeasonDto { StartDate = DateTime.Today, EndDate = DateTime.Today.AddMonths(6) };
            selectedMatchTypeId = 0;
        }
    }

    private async Task AddTeam()
    {
        var response = await Http.PostAsJsonAsync("api/teams", newTeam);
        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<TeamDto>();
            teams?.Add(created!);
            newTeam = new CreateTeamDto();
        }
    }

    private async Task AddPlayer()
    {
        var response = await Http.PostAsJsonAsync("api/players", newPlayer);
        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<PlayerDto>();
            players?.Add(created!);
            newPlayer = new CreatePlayerDto { IsActive = true };
        }
    }
}
