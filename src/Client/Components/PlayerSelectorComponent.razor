@using DartPerformanceTracker.Shared.DTOs

<div>
    <label class="form-label">@Label</label>
    <div class="player-checkboxes">
        @foreach (var player in Players.Where(p => p.IsActive))
        {
            var isSelected = SelectedPlayerIds.Contains(player.Id);
            var isDisabled = !isSelected && MaxSelections > 0 && SelectedPlayerIds.Count >= MaxSelections;
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox"
                       id="@($"{Prefix}_player_{player.Id}")"
                       checked="@isSelected"
                       disabled="@isDisabled"
                       @onchange="e => TogglePlayer(player.Id, (bool)e.Value!)" />
                <label class="form-check-label" for="@($"{Prefix}_player_{player.Id}")">@player.Name</label>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public List<PlayerDto> Players { get; set; } = new();
    [Parameter, EditorRequired] public List<int> SelectedPlayerIds { get; set; } = new();
    [Parameter] public EventCallback<List<int>> SelectedPlayerIdsChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Select Players";
    [Parameter] public int MaxSelections { get; set; } = 0;
    [Parameter] public string Prefix { get; set; } = "sel";

    private async Task TogglePlayer(int playerId, bool selected)
    {
        if (selected)
        {
            if (!SelectedPlayerIds.Contains(playerId))
                SelectedPlayerIds.Add(playerId);
        }
        else
        {
            SelectedPlayerIds.Remove(playerId);
        }
        await SelectedPlayerIdsChanged.InvokeAsync(SelectedPlayerIds);
    }
}
