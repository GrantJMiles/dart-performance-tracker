<ApexChart TItem="GameNightSummaryDto"
           Title="Team Performance"
           Options="@options"
           Height="260">

    <ApexPointSeries TItem="GameNightSummaryDto"
                     Items="@Items"
                     Name="Matches Won"
                     SeriesType="SeriesType.Line"
                     XValue="@(e => e.Date.ToString("dd MMM"))"
                     YValue="@(e => (decimal)e.MatchesWon)" />

    <ApexPointSeries TItem="GameNightSummaryDto"
                     Items="@Items"
                     Name="Tons"
                     SeriesType="SeriesType.Line"
                     XValue="@(e => e.Date.ToString("dd MMM"))"
                     YValue="@(e => (decimal)e.TotalTons)" />

    <ApexPointSeries TItem="GameNightSummaryDto"
                     Items="@Items"
                     Name="Maximums"
                     SeriesType="SeriesType.Line"
                     XValue="@(e => e.Date.ToString("dd MMM"))"
                     YValue="@(e => (decimal)e.TotalMaximums)" />

</ApexChart>

@code {
    [Parameter, EditorRequired] public List<GameNightSummaryDto> Items { get; set; } = new();

    private ApexChartOptions<GameNightSummaryDto> options = new()
    {
        Chart = new Chart
        {
            Toolbar = new Toolbar { Show = false },
            Background = "transparent"
        },
        Colors = new List<string> { "#10b981", "#f59e0b", "#3b82f6" },
        Legend = new Legend { Position = LegendPosition.Top },
        Stroke = new Stroke
        {
            Curve = Curve.Smooth,
            Width = new List<int> { 2, 2, 2 }
        },
        Markers = new Markers { Size = 4 },
        Xaxis = new XAxis
        {
            Labels = new XAxisLabels
            {
                Style = new AxisLabelStyle { FontFamily = "inherit", FontSize = "12px" }
            }
        },
        Yaxis = new List<YAxis>
        {
            new YAxis
            {
                Min = 0,
                ForceNiceScale = true,
                Labels = new YAxisLabels
                {
                    Style = new AxisLabelStyle { FontFamily = "inherit", FontSize = "12px" }
                }
            }
        },
        Theme = new Theme { Mode = Mode.Light }
    };
}
