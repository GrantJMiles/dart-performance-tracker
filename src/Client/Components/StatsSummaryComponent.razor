@using DartPerformanceTracker.Shared.DTOs

<div style="margin-top: 0.75rem;">
    <h5>@Label</h5>
    @if (Items == null || !Items.Any())
    {
        <p style="color: var(--neutral-foreground-hint);">No data available.</p>
    }
    else
    {
        <ul style="list-style: none; padding: 0; margin: 0;">
            @foreach (var item in Items)
            {
                <li style="padding: 0.5rem 0; border-bottom: 1px solid var(--neutral-stroke-rest);">@item</li>
            }
        </ul>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public List<string>? Items { get; set; }
}
