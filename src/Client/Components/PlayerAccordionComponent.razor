@using DartPerformanceTracker.Shared.DTOs

@if (Players != null && Players.Any())
{
    <div class="results-card">
        <p class="section-title">Players</p>

        @* Tab buttons *@
        <div class="player-stats-tabs">
            <button class="player-tab-btn @(activeTab == "overall" ? "active" : "")" @onclick='() => SetTab("overall")'>Overall</button>
            <button class="player-tab-btn @(activeTab == "singles" ? "active" : "")" @onclick='() => SetTab("singles")'>Singles</button>
            <button class="player-tab-btn @(activeTab == "pairs" ? "active" : "")" @onclick='() => SetTab("pairs")'>Pairs</button>
        </div>

        @* Header row *@
        <div class="player-accordion-header-row">
            <span class="player-col-name">Player</span>
            <span class="player-col-form">Form</span>
            <span class="player-col-stat">Played</span>
            <span class="player-col-stat">Won</span>
            <span class="player-col-stat">Win%</span>
            <span class="player-col-stat">Tons</span>
            <span class="player-col-stat">@($"{MaximumScore}s")</span>
            <span class="player-col-stat">+/-</span>
            <span class="player-col-motm">MOTM</span>
        </div>

        @foreach (var player in GetFilteredPlayers())
        {
            var breakdowns = GetBreakdowns(player).ToList();
            var totalPlayed = breakdowns.Sum(b => b.MatchesPlayed);
            var totalWon = breakdowns.Sum(b => b.MatchesWon);
            var totalTons = breakdowns.Sum(b => b.Tons);
            var totalMaximums = breakdowns.Sum(b => b.Maximums);
            var totalLegsWon = breakdowns.Sum(b => b.LegsWon);
            var totalLegsLost = breakdowns.Sum(b => b.LegsLost);
            var legsDiff = totalLegsWon - totalLegsLost;
            var winPct = totalPlayed > 0 ? Math.Round((double)totalWon / totalPlayed * 100, 0) : 0;
            var isExpanded = expandedPlayerId == player.PlayerId;
            var recentForm = GetRecentForm(player);

            <div class="player-accordion-row @(isExpanded ? "expanded" : "")"
                 @onclick="() => TogglePlayer(player.PlayerId)"
                 style="cursor: pointer;">
                <span class="player-col-name fw-semibold">@player.PlayerName</span>
                <span class="player-col-form">
                    @foreach (var r in recentForm)
                    {
                        <span class="player-form-pip @(r.Won ? "pip-won" : "pip-lost")">@(r.Won ? "W" : "L")</span>
                    }
                </span>
                <span class="player-col-stat">@totalPlayed</span>
                <span class="player-col-stat">@totalWon</span>
                <span class="player-col-stat">
                    <span style="color: @(winPct >= 50 ? "var(--color-won, #4caf82)" : "var(--color-lost, #e05c5c)"); font-weight: 600;">@winPct%</span>
                </span>
                <span class="player-col-stat">@totalTons</span>
                <span class="player-col-stat">@totalMaximums</span>
                <span class="player-col-stat">
                    <span style="color: @(legsDiff >= 0 ? "var(--color-won)" : "var(--color-lost)"); font-weight: 600;">@(legsDiff >= 0 ? "+" : "")@legsDiff</span>
                </span>
                @if (activeTab == "overall")
                {
                    <span class="player-col-motm">@(player.ManOfTheMatchCount > 0 ? $"⭐ {player.ManOfTheMatchCount}" : "—")</span>
                }
                else
                {
                    <span class="player-col-motm"></span>
                }
            </div>

            @if (isExpanded)
            {
                <div class="player-accordion-detail">
                    @if (breakdowns.Any())
                    {
                        <p class="small fw-semibold mb-1 text-muted">Match Type Breakdown</p>
                        <table class="table table-sm mb-3" style="font-size: 0.83rem;">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Played</th>
                                    <th>Won</th>
                                    <th>Win%</th>
                                    <th>Legs W</th>
                                    <th>Legs L</th>
                                    <th>+/-</th>
                                    <th>Tons</th>
                                    <th>@($"{MaximumScore}s")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var breakdown in breakdowns)
                                {
                                    var bWinPct = breakdown.MatchesPlayed > 0
                                        ? Math.Round((double)breakdown.MatchesWon / breakdown.MatchesPlayed * 100, 0)
                                        : 0;
                                    var bLegsDiff = breakdown.LegsWon - breakdown.LegsLost;
                                    <tr>
                                        <td>@breakdown.MatchTypeName</td>
                                        <td>@breakdown.MatchesPlayed</td>
                                        <td>@breakdown.MatchesWon</td>
                                        <td>
                                            <span class="win-pct-badge @(bWinPct >= 50 ? "badge-won" : "badge-lost")">@bWinPct%</span>
                                        </td>
                                        <td>@breakdown.LegsWon</td>
                                        <td>@breakdown.LegsLost</td>
                                        <td style="color: @(bLegsDiff >= 0 ? "var(--color-won)" : "var(--color-lost)"); font-weight: 600;">@(bLegsDiff >= 0 ? "+" : "")@bLegsDiff</td>
                                        <td>@breakdown.Tons</td>
                                        <td>@breakdown.Maximums</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @if (player.TopPairings.Any())
                    {
                        <p class="small fw-semibold mb-1 text-muted">Pairings</p>
                        <div class="d-flex gap-2 flex-wrap">
                            @foreach (var pairing in player.TopPairings)
                            {
                                <div class="p-2 rounded" style="background: rgba(255,255,255,0.05); min-width: 140px;">
                                    <div class="fw-semibold small">@pairing.PartnerName</div>
                                    <div class="text-muted" style="font-size:0.78rem;">@pairing.MatchesWon W / @pairing.MatchesPlayed played</div>
                                    <span class="win-pct-badge @(pairing.WinRatio >= 50 ? "badge-won" : "badge-lost")">@pairing.WinRatio%</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
}

<style>
    .player-stats-tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 10px;
    }

    .player-tab-btn {
        padding: 4px 14px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.2);
        background: transparent;
        color: var(--text-muted, #aaa);
        font-size: 0.78rem;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
    }

    .player-tab-btn.active {
        background: var(--color-accent, #5b8dee);
        border-color: var(--color-accent, #5b8dee);
        color: #fff;
        font-weight: 600;
    }

    .player-accordion-header-row,
    .player-accordion-row {
        display: grid;
        grid-template-columns: 1fr 90px 60px 50px 60px 50px 50px 55px 60px;
        align-items: center;
        padding: 8px 4px;
        gap: 4px;
    }

    .player-accordion-header-row {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--text-muted, #aaa);
        border-bottom: 1px solid rgba(255,255,255,0.15);
        padding-bottom: 6px;
        margin-bottom: 2px;
    }

    .player-accordion-row {
        border-bottom: 1px solid rgba(255,255,255,0.06);
        font-size: 0.88rem;
        transition: background 0.15s;
    }

    .player-accordion-row:hover,
    .player-accordion-row.expanded {
        background: rgba(255,255,255,0.04);
        border-radius: 6px;
    }

    .player-col-name { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .player-col-form { display: flex; gap: 2px; align-items: center; flex-wrap: nowrap; }
    .player-col-stat { text-align: right; white-space: nowrap; }
    .player-col-motm { text-align: right; white-space: nowrap; }

    .player-form-pip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 16px;
        height: 16px;
        border-radius: 3px;
        font-size: 0.62rem;
        font-weight: 700;
        line-height: 1;
        flex-shrink: 0;
    }

    .player-form-pip.pip-won { background: var(--color-won, #4caf82); color: #fff; }
    .player-form-pip.pip-lost { background: var(--color-lost, #e05c5c); color: #fff; }

    .player-accordion-detail {
        padding: 10px 4px 14px 8px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .player-accordion-detail .table th,
    .player-accordion-detail .table td {
        padding: 4px 8px;
        white-space: nowrap;
    }
</style>

@code {
    [Parameter] public List<TeamPlayerSeasonStatsDto>? Players { get; set; }
    [Parameter] public int MaximumScore { get; set; } = 180;

    private int? expandedPlayerId;
    private string activeTab = "overall";

    private void TogglePlayer(int playerId)
    {
        expandedPlayerId = expandedPlayerId == playerId ? null : playerId;
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
        expandedPlayerId = null;
    }

    private IEnumerable<PlayerMatchTypeBreakdownDto> GetBreakdowns(TeamPlayerSeasonStatsDto player)
    {
        return activeTab switch
        {
            "singles" => player.MatchTypeBreakdowns.Where(b => b.MatchTypeName == "Singles"),
            "pairs" => player.MatchTypeBreakdowns.Where(b => b.MatchTypeName is "Pairs" or "Blind Pairs"),
            _ => player.MatchTypeBreakdowns
        };
    }

    private IEnumerable<PlayerRecentResultDto> GetRecentForm(TeamPlayerSeasonStatsDto player)
    {
        return activeTab switch
        {
            "singles" => player.RecentResults.Where(r => r.MatchTypeName == "Singles").TakeLast(5),
            "pairs" => player.RecentResults.Where(r => r.MatchTypeName is "Pairs" or "Blind Pairs").TakeLast(5),
            _ => player.RecentResults.TakeLast(5)
        };
    }

    private IEnumerable<TeamPlayerSeasonStatsDto> GetFilteredPlayers()
    {
        if (Players == null) return Enumerable.Empty<TeamPlayerSeasonStatsDto>();
        if (activeTab == "overall") return Players;
        return Players.Where(p => GetBreakdowns(p).Any());
    }
}
