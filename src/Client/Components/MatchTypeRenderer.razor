@using DartPerformanceTracker.Shared.DTOs

<FluentBadge Appearance="Appearance.Accent" Style="margin-right: 4px;">@MatchTypeName</FluentBadge>
<span style="color: var(--neutral-foreground-hint); font-size: 0.875rem;">(@PlayersPerSide v @PlayersPerSide)</span>

@code {
    [Parameter, EditorRequired] public string MatchTypeName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public int PlayersPerSide { get; set; }
}
