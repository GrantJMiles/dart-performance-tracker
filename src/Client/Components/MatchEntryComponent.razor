@using DartPerformanceTracker.Shared.DTOs

<div class="card mb-3">
    <div class="card-header">
        <MatchTypeRenderer MatchTypeName="@Config.MatchTypeName" PlayersPerSide="@Config.PlayersPerSide" /> &mdash; Match @MatchNumber
    </div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-6 col-sm-4">
                <label class="form-label">Legs Won</label>
                <input type="number" class="form-control" min="0" @bind="Match.LegsWon" />
            </div>
            <div class="col-6 col-sm-4">
                <label class="form-label">Legs Lost</label>
                <input type="number" class="form-control" min="0" @bind="Match.LegsLost" />
            </div>
            @if (Match.LegsWon != 0 || Match.LegsLost != 0)
            {
                <div class="col-12 col-sm-4 d-flex align-items-end pb-1">
                    <span class="badge @(Match.LegsWon > Match.LegsLost ? "bg-success" : Match.LegsWon < Match.LegsLost ? "bg-danger" : "bg-secondary") fs-6">
                        @(Match.LegsWon > Match.LegsLost ? "Win" : Match.LegsWon < Match.LegsLost ? "Loss" : "Draw")
                    </span>
                </div>
            }
        </div>
        <div class="mt-3">
            <label class="form-label">Players (@Config.PlayersPerSide per side)</label>
            <PlayerSelectorComponent
                Players="Players"
                SelectedPlayerIds="Match.PlayerIds"
                SelectedPlayerIdsChanged="OnPlayerIdsChanged"
                Prefix="@($"match_{Config.MatchTypeId}_{MatchNumber}")"
                Label="Select Players"
                MaxSelections="Config.PlayersPerSide" />
        </div>
        @if (Match.PlayerStats.Any())
        {
            <div class="mt-3">
                <label class="form-label">Player Stats</label>
                @foreach (var stat in Match.PlayerStats)
                {
                    var playerName = Players.FirstOrDefault(p => p.Id == stat.PlayerId)?.Name ?? stat.PlayerId.ToString();
                    <div class="row g-2 mt-1 align-items-center">
                        <div class="col-12 col-sm-4"><strong>@playerName</strong></div>
                        <div class="col-6 col-sm-4">
                            <label class="form-label mb-1 small">Tons</label>
                            <input type="number" class="form-control form-control-sm" min="0" @bind="stat.Tons" />
                        </div>
                        <div class="col-6 col-sm-4">
                            <label class="form-label mb-1 small">Maximums (@MaximumScore)</label>
                            <input type="number" class="form-control form-control-sm" min="0" @bind="stat.Maximums" />
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public SeasonMatchConfigurationDto Config { get; set; } = null!;
    [Parameter, EditorRequired] public List<PlayerDto> Players { get; set; } = new();
    [Parameter, EditorRequired] public UpdateMatchDto Match { get; set; } = null!;
    [Parameter] public int MatchNumber { get; set; } = 1;
    [Parameter] public int MaximumScore { get; set; } = 180;

    private void OnPlayerIdsChanged(List<int> updatedIds)
    {
        Match.PlayerStats.RemoveAll(s => !updatedIds.Contains(s.PlayerId));
        foreach (var id in updatedIds.Where(id => !Match.PlayerStats.Any(s => s.PlayerId == id)))
            Match.PlayerStats.Add(new CreatePlayerMatchStatsDto { PlayerId = id });
        StateHasChanged();
    }
}
