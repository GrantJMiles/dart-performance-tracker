@using DartPerformanceTracker.Shared.DTOs

<div class="card mb-3">
    <div class="card-header">
        <MatchTypeRenderer MatchTypeName="@Config.MatchTypeName" PlayersPerSide="@Config.PlayersPerSide" /> &mdash; Match @MatchNumber
    </div>
    <div class="card-body">
        <label class="form-label">Result</label>
        <div class="score-picker">
            @foreach (var option in ScoreOptions)
            {
                var isSelected = Match.LegsWon == option.Won && Match.LegsLost == option.Lost;
                <button type="button"
                        class="score-btn @option.Theme @(isSelected ? "selected" : "")"
                        aria-pressed="@isSelected"
                        @onclick="() => SetScore(option.Won, option.Lost)">
                    <span class="score-btn-label">@option.Won&ndash;@option.Lost</span>
                    <span class="score-btn-sublabel">@option.Label</span>
                </button>
            }
        </div>

        <div class="mt-3">
            <PlayerSelectorComponent
                Players="Players"
                SelectedPlayerIds="Match.PlayerIds"
                SelectedPlayerIdsChanged="OnPlayerIdsChanged"
                Prefix="@($"match_{Config.MatchTypeId}_{MatchNumber}")"
                Label="@($"Players ({Config.PlayersPerSide} per side)")"
                MaxSelections="Config.PlayersPerSide" />
        </div>

        @if (Match.PlayerStats.Any())
        {
            <div class="mt-3">
                <label class="form-label">Player Stats</label>
                @foreach (var stat in Match.PlayerStats)
                {
                    var playerName = Players.FirstOrDefault(p => p.Id == stat.PlayerId)?.Name ?? stat.PlayerId.ToString();
                    <div class="stat-row">
                        <span class="stat-player-name">@playerName</span>
                        <div class="stat-stepper-group">
                            <span class="stat-stepper-label">Tons</span>
                            <div class="stat-stepper">
                                <button type="button" class="stepper-btn" aria-label="Decrease tons" @onclick="() => stat.Tons = Math.Max(0, stat.Tons - 1)">−</button>
                                <span class="stepper-value">@stat.Tons</span>
                                <button type="button" class="stepper-btn" aria-label="Increase tons" @onclick="() => stat.Tons++">+</button>
                            </div>
                        </div>
                        <div class="stat-stepper-group">
                            <span class="stat-stepper-label">@MaximumScore</span>
                            <div class="stat-stepper">
                                <button type="button" class="stepper-btn" aria-label="Decrease maximums" @onclick="() => stat.Maximums = Math.Max(0, stat.Maximums - 1)">−</button>
                                <span class="stepper-value">@stat.Maximums</span>
                                <button type="button" class="stepper-btn" aria-label="Increase maximums" @onclick="() => stat.Maximums++">+</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public SeasonMatchConfigurationDto Config { get; set; } = null!;
    [Parameter, EditorRequired] public List<PlayerDto> Players { get; set; } = new();
    [Parameter, EditorRequired] public UpdateMatchDto Match { get; set; } = null!;
    [Parameter] public int MatchNumber { get; set; } = 1;
    [Parameter] public int MaximumScore { get; set; } = 180;

    private record ScoreOption(int Won, int Lost, string Label, string Theme);

    private static readonly List<ScoreOption> ScoreOptions = new()
    {
        new(2, 0, "Win", "win"),
        new(2, 1, "Win", "win-close"),
        new(1, 2, "Loss", "loss-close"),
        new(0, 2, "Loss", "loss"),
    };

    private void SetScore(int won, int lost)
    {
        Match.LegsWon = won;
        Match.LegsLost = lost;
    }

    private void OnPlayerIdsChanged(List<int> updatedIds)
    {
        Match.PlayerStats.RemoveAll(s => !updatedIds.Contains(s.PlayerId));
        foreach (var id in updatedIds.Where(id => !Match.PlayerStats.Any(s => s.PlayerId == id)))
            Match.PlayerStats.Add(new CreatePlayerMatchStatsDto { PlayerId = id });
        StateHasChanged();
    }
}
