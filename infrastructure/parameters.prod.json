{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "prod"
    },
    "location": {
      "value": "uksouth"
    },
    "sqlAdminLogin": {
      "value": "darttracker-admin"
    },
    "sqlAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subscription-id>/resourceGroups/dart-tracker-rg/providers/Microsoft.KeyVault/vaults/<keyvault-name>"
        },
        "secretName": "sql-admin-password"
      }
    }
  }
}
